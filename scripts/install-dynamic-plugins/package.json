    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write ."
  },
  "dependencies": {
    "tar": "^7.5.13",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/tar": "^6.1.13",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.25.0",
    "prettier": "^3.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
