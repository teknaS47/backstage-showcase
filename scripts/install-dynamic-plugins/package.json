{
  "name": "@rhdh/install-dynamic-plugins",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Install dynamic plugins into a RHDH instance from a dynamic-plugins.yaml config (OCI, NPM, local).",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "install-dynamic-plugins": "dist/install-dynamic-plugins.cjs"
  },
  "scripts": {
